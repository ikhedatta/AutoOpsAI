# =============================================================================
# AutoOps AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
#   cp .env.example .env
#
# All values below show their defaults. Uncomment and change as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama (Local LLM)
# -----------------------------------------------------------------------------
# Base URL of the Ollama API server.
OLLAMA_BASE=http://localhost:11434

# Default model to use for inference. Must be pulled first: ollama pull <model>
OLLAMA_MODEL=qwen3:4b

# -----------------------------------------------------------------------------
# Microsoft Teams — Bot Framework
# -----------------------------------------------------------------------------
# Azure Bot Service app credentials. Required for two-way Teams integration.
# Leave blank for local development without Teams.
TEAMS_BOT_ENABLED=false
TEAMS_APP_ID=
TEAMS_APP_SECRET=
TEAMS_TENANT_ID=

# Incoming Webhook URL for pushing alerts/cards to a Teams channel (one-way).
# Create one in Teams: channel > Connectors > Incoming Webhook.
TEAMS_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Observability Stack (used by prometheus_grafana POC)
# -----------------------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=
LOKI_URL=http://localhost:3100

# -----------------------------------------------------------------------------
# MongoDB — Persistence Layer
# -----------------------------------------------------------------------------
# Connection URI for MongoDB (used for incident history, audit logs, conversations)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=autoopsai

# Legacy: tool_execution POC also uses this for diagnostic queries
MONGODB_HOST=localhost:27017

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Uncomment to point at a remote Docker daemon instead of the local socket.
# DOCKER_HOST=unix:///var/run/docker.sock

# -----------------------------------------------------------------------------
# Pipeline settings
# -----------------------------------------------------------------------------
OLLAMA_TIMEOUT=120
MAX_HISTORY_ITEMS=1000
MAX_CONVERSATION_HISTORY=20
AUDIT_LOG_PATH=./audit.log
PLAYBOOKS_DIR=./POCs/playbook_matching/playbooks
